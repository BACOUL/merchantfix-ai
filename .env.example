# MerchantFix.ai environment variables example
# This file is safe to commit because it contains placeholders only.
# Never commit .env or .env.local with real secrets.

# Application
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=MerchantFix.ai

# Environment
NODE_ENV=development

# Stripe - V2 only
# Do not use Stripe in V1.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# OpenAI - V3 only
# Do not use AI in V1.
OPENAI_API_KEY=

# Supabase - V4 only
# Do not use database or authentication in V1.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Shopify API - V5 only
# Do not use Shopify API in V1.
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_APP_URL=

# Google Merchant Center API - V5 only
# Do not use Google API in V1.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# File storage - later versions only
# V1 should avoid persistent customer file storage.
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=

# Security
# Use a strong random value if sessions are implemented later.
SESSION_SECRET=
